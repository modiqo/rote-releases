#!/bin/bash
set -e

# rote VS Code extension installer
# Usage: curl -fsSL https://getrote.dev/install-vscode | bash
#
# Downloads the latest .vsix from modiqo/rote-releases and installs it.
# VS Code releases are published as pre-releases with "vscode-v{VERSION}" tags.
# Requires: code (VS Code) on PATH.

REPO="modiqo/rote-releases"
BOLD='\033[1m'
GREEN='\033[0;32m'
RED='\033[0;31m'
DIM='\033[2m'
NC='\033[0m'

echo ""
printf "  ${BOLD}rote${NC} ${DIM}· VS Code extension installer${NC}\n"
echo ""

# Check VS Code is available
if ! command -v code >/dev/null 2>&1; then
    printf "  ${RED}✗${NC} VS Code CLI (code) not found on PATH.\n"
    printf "  ${DIM}  Open VS Code → Cmd+Shift+P → 'Shell Command: Install code'${NC}\n"
    exit 1
fi

# Find the latest vscode-v* release (these are pre-releases, so /releases/latest won't find them)
printf "  ${DIM}Resolving latest version...${NC}\r"
TAG=$(curl -fsSL "https://api.github.com/repos/$REPO/releases?per_page=20" 2>/dev/null \
    | grep '"tag_name"' | sed -E 's/.*"([^"]+)".*/\1/' | grep '^vscode-v' | head -1)

if [ -z "$TAG" ]; then
    printf "  ${RED}✗${NC} No VS Code extension releases found on ${REPO}.\n"
    printf "  ${DIM}  Releases must be tagged vscode-v{VERSION} on ${REPO}.${NC}\n"
    exit 1
fi

VERSION="${TAG#vscode-v}"
printf "  ${GREEN}●${NC} Found v${VERSION}\n"

DOWNLOAD_URL="https://releases.getrote.dev/${TAG}/rote-${VERSION}.vsix"
VSIX_FILE="/tmp/rote-vscode-${VERSION}.vsix"

if ! curl -fsSL "$DOWNLOAD_URL" -o "$VSIX_FILE"; then
    printf "  ${RED}✗${NC} Download failed: $DOWNLOAD_URL\n"
    exit 1
fi

# Install
printf "  ${DIM}Installing extension...${NC}\r"
code --install-extension "$VSIX_FILE" --force >/dev/null 2>&1

rm -f "$VSIX_FILE"

echo ""
printf "  ${GREEN}●${NC} ${BOLD}rote${NC} extension installed.\n"
printf "  ${DIM}  Reload VS Code to activate.${NC}\n"
echo ""
